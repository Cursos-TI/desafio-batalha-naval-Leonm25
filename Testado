#include <stdio.h>

int main() {

    // Criando tabuleiro 10x10
    int tabuleiro[10][10] = {0};

    // Navio horizontal (linha 0, colunas 0 a 2)
    for(int j = 0; j < 3; j++) {
        tabuleiro[0][j] = 3;
    }

    // Navio vertical (coluna 5, linhas 1 a 3)
    for(int i = 1; i < 4; i++) {
        tabuleiro[i][5] = 3;
    }

    // Navio diagonal principal
    for(int i = 0; i < 3; i++) {
        tabuleiro[i][i] = 3;
    }

    // Navio diagonal secundária
    for(int i = 0; i < 3; i++) {
        tabuleiro[i][9 - i] = 3;
    }

    // Exibindo o tabuleiro
    printf("TABULEIRO:\n\n");

    for(int i = 0; i < 10; i++) {
        for(int j = 0; j < 10; j++) {
            printf("%d ", tabuleiro[i][j]);
        }
        printf("\n");
    }

    return 0;
}
